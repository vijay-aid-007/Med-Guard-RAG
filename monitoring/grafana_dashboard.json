{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "MedGuard RAG — Production Monitoring Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 0.8 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "targets": [{
        "expr": "sum(medguard_requests_total)",
        "legendFormat": "Total"
      }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "title": "Guardrail Blocks",
      "type": "stat",
      "targets": [{
        "expr": "sum(medguard_guardrail_blocks_total)",
        "legendFormat": "Blocks"
      }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "title": "Avg Response Time (ms)",
      "type": "stat",
      "targets": [{
        "expr": "avg(medguard_response_latency_ms)",
        "legendFormat": "Latency"
      }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "title": "Handoffs Triggered",
      "type": "stat",
      "targets": [{
        "expr": "sum(medguard_handoffs_total)",
        "legendFormat": "Handoffs"
      }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "title": "Avg Grounding Score",
      "type": "stat",
      "targets": [{
        "expr": "avg(medguard_grounding_score)",
        "legendFormat": "Grounding"
      }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 6,
      "title": "Request Rate Over Time",
      "type": "timeseries",
      "targets": [{
        "expr": "rate(medguard_requests_total[5m])",
        "legendFormat": "Requests/sec"
      }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 7,
      "title": "Pipeline Status Breakdown",
      "type": "piechart",
      "targets": [{
        "expr": "sum by(status) (medguard_pipeline_status_total)",
        "legendFormat": "{{status}}"
      }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 8,
      "title": "Guardrail Blocks by Reason",
      "type": "bargauge",
      "targets": [{
        "expr": "sum by(reason) (medguard_guardrail_blocks_total)",
        "legendFormat": "{{reason}}"
      }]
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 9,
      "title": "Response Latency Distribution",
      "type": "histogram",
      "targets": [{
        "expr": "medguard_response_latency_ms_bucket",
        "legendFormat": "{{le}}"
      }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["medguard", "rag", "medical"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "MedGuard RAG — Production Dashboard",
  "uid": "medguard-rag-v1",
  "version": 1
}